---
// Wordmark: a cog mark (echoes the logo gear + the machines' hex truss) plus the
// two-line LIEVENSE / CONSTRUCTIE lockup. Text uses currentColor so it adapts to
// dark hero vs. frosted header; the gear keeps its industrial yellow.
interface Props { class?: string; compact?: boolean }
const { class: klass = "", compact = false } = Astro.props;
---
<span class:list={["inline-flex items-center gap-2.5", klass]}>
  <svg width="30" height="30" viewBox="0 0 48 48" fill="none" aria-hidden="true" class="shrink-0">
    <path
      d="M24 2.5l3.4 3.1 4.4-1.4 1.9 4.2 4.6.3.2 4.6 4.2 1.9-1.4 4.4 3.1 3.4-3.1 3.4 1.4 4.4-4.2 1.9-.2 4.6-4.6.3-1.9 4.2-4.4-1.4L24 45.5l-3.4-3.1-4.4 1.4-1.9-4.2-4.6-.3-.2-4.6-4.2-1.9 1.4-4.4L3.9 24l3.1-3.4-1.4-4.4 4.2-1.9.2-4.6 4.6-.3 1.9-4.2 4.4 1.4L24 2.5z"
      fill="currentColor" opacity="0.9"
    />
    <path d="M24 9a15 15 0 1 0 15 15" fill="none" stroke="var(--color-accent-500)" stroke-width="4" stroke-linecap="round" />
    <circle cx="24" cy="24" r="6.5" fill="var(--color-accent-500)" />
  </svg>
  {!compact && (
    <span class="nav-mark-word leading-[0.86]">
      <span class="font-display block text-[1.02rem] tracking-[0.02em]" style="font-stretch:112%;font-weight:800;">LIEVENSE</span>
      <span class="font-mono block text-[0.58rem] tracking-[0.3em] uppercase opacity-55">Constructie</span>
    </span>
  )}
</span>
