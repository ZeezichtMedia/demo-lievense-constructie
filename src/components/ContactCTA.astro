---
import { site } from "../lib/site";
interface Props { image?: string }
const { image = "/images/lievense/oogst-actie.jpg" } = Astro.props;
---
<section id="contact-cta" class="grain relative overflow-hidden bg-dark text-base">
  <div class="absolute inset-0 opacity-25">
    <img src={image} alt="" class="h-full w-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/85 to-dark/40"></div>
  </div>
  <div class="container-wide relative z-10 section-lg">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p class="eyebrow-bone reveal">Overleg of offerte</p>
        <h2 class="reveal mt-6 type-display-lg text-base heading-balance">
          Een machine of constructie <span class="text-accent-300">op maat</span> nodig?
        </h2>
        <p class="reveal mt-6 type-lead max-w-xl text-base/75">
          Bel of mail even. We denken mee over gewas, maaidorser en werkwijze en komen met een oplossing die past.
        </p>
        <div class="reveal mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href={site.phoneHref} class="btn-primary bg-base text-ink hover:bg-accent-300">Bel {site.phone}</a>
          <a href="/contact" class="btn-ghost border-base/30 text-base hover:bg-base/10">Stuur een aanvraag</a>
        </div>
      </div>
      <div class="reveal lg:col-span-4 lg:col-start-9">
        <div class="space-y-4 border-t border-base/15 pt-6 font-mono text-sm">
          <a href={site.phoneHref} class="flex items-center justify-between gap-4 text-base/80 transition hover:text-accent-300">
            <span class="text-base/45">Telefoon</span><span>{site.phone}</span>
          </a>
          <a href={site.emailHref} class="flex items-center justify-between gap-4 text-base/80 transition hover:text-accent-300">
            <span class="text-base/45">E-mail</span><span>{site.email}</span>
          </a>
          <div class="flex items-center justify-between gap-4 text-base/80">
            <span class="text-base/45">Regio</span><span>{site.region}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
