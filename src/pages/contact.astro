---
import Layout from "../layouts/Layout.astro";
import { site, services } from "../lib/site";
---
<Layout
  title="Contact · Lievense Constructie"
  description="Neem contact op met Lievense Constructie voor bandoprapers, constructiewerk, aandrijftechniek, onderhoud en agrarisch loonwerk."
  heroTone="dark"
>
  <section class="section-xl bg-base pt-36 md:pt-44">
    <div class="container-wide">
      <div class="grid gap-16 lg:grid-cols-12">
        <!-- Left: intro + details -->
        <div class="lg:col-span-5">
          <p class="eyebrow reveal">Contact</p>
          <h1 class="reveal mt-6 type-display-lg text-ink heading-balance">
            Even <span class="text-outline-ink">overleggen?</span>
          </h1>
          <p class="reveal mt-6 type-lead text-ink-muted max-w-md">
            Vertel kort wat u zoekt. Bel of mail rechtstreeks, of stuur het formulier in. We reageren zo snel mogelijk.
          </p>

          <div class="reveal mt-12 space-y-5">
            <a href={site.phoneHref} class="group flex items-center justify-between gap-4 border-t border-line py-5 transition hover:border-ink">
              <span>
                <span class="block font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">Telefoon</span>
                <span class="mt-1 block font-display text-xl text-ink" style="font-stretch:112%;font-weight:700;">{site.phone}</span>
              </span>
              <span class="text-ink-faint transition group-hover:translate-x-1 group-hover:text-accent-600" aria-hidden="true">&rarr;</span>
            </a>
            <a href={site.emailHref} class="group flex items-center justify-between gap-4 border-t border-line py-5 transition hover:border-ink">
              <span>
                <span class="block font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">E-mail</span>
                <span class="mt-1 block font-display text-xl text-ink break-all" style="font-stretch:112%;font-weight:700;">{site.email}</span>
              </span>
              <span class="text-ink-faint transition group-hover:translate-x-1 group-hover:text-accent-600" aria-hidden="true">&rarr;</span>
            </a>
            <div class="flex items-center justify-between gap-4 border-t border-b border-line py-5">
              <span>
                <span class="block font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">Regio</span>
                <span class="mt-1 block font-display text-xl text-ink" style="font-stretch:112%;font-weight:700;">{site.region}</span>
              </span>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="lg:col-span-6 lg:col-start-7">
          <form id="contact-form" class="reveal space-y-12" novalidate>
            <div class="space-y-3">
              <label for="naam" class="eyebrow-ink">Naam</label>
              <input id="naam" name="naam" type="text" required autocomplete="name" class="field-line" placeholder="Uw naam" />
            </div>

            <div class="grid gap-8 sm:grid-cols-2">
              <div class="space-y-3">
                <label for="email" class="eyebrow-ink">E-mail</label>
                <input id="email" name="email" type="email" required autocomplete="email" class="field-line" placeholder="naam@bedrijf.nl" />
              </div>
              <div class="space-y-3">
                <label for="telefoon" class="eyebrow-ink">Telefoon</label>
                <input id="telefoon" name="telefoon" type="tel" autocomplete="tel" class="field-line" placeholder="Optioneel" />
              </div>
            </div>

            <fieldset class="space-y-4">
              <legend class="eyebrow-ink">Waar gaat het over?</legend>
              <div class="grid gap-3 sm:grid-cols-2">
                {services.map((s, i) => (
                  <label class="opt flex items-start gap-3 p-4">
                    <input type="radio" name="onderwerp" value={s.title} class="sr-only" checked={i === 0} />
                    <span>
                      <span class="block font-medium text-ink">{s.title}</span>
                      <span class="mt-0.5 block text-sm text-ink-muted">{s.short}</span>
                    </span>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="space-y-3">
              <label for="bericht" class="eyebrow-ink">Uw vraag</label>
              <textarea id="bericht" name="bericht" rows="4" class="field-line" placeholder="Machine, gewas, werkbreedte of wat u verder wilt weten"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center py-4 text-base">Verstuur aanvraag</button>
            <p id="form-note" class="hidden font-mono text-xs uppercase tracking-[0.1em] text-accent-600"></p>
            <p class="text-xs text-ink-faint">
              Dit is een redesign-demo. Het formulier opent uw eigen mailprogramma en verstuurt niets automatisch.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ mail: site.email }}>
    const form = document.getElementById("contact-form");
    const note = document.getElementById("form-note");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const naam = (data.get("naam") || "").toString().trim();
      const email = (data.get("email") || "").toString().trim();
      if (!naam || !email) {
        note.textContent = "Vul uw naam en e-mail in.";
        note.classList.remove("hidden");
        return;
      }
      const onderwerp = (data.get("onderwerp") || "Aanvraag").toString();
      const body = [
        `Naam: ${naam}`,
        `E-mail: ${email}`,
        `Telefoon: ${(data.get("telefoon") || "-").toString()}`,
        `Onderwerp: ${onderwerp}`,
        "",
        (data.get("bericht") || "").toString(),
      ].join("\n");
      const href = `mailto:${mail}?subject=${encodeURIComponent("Aanvraag: " + onderwerp)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
      note.textContent = "Uw mailprogramma wordt geopend.";
      note.classList.remove("hidden");
    });
  </script>
</Layout>
