---
import Layout from "../layouts/Layout.astro";
import Marquee from "../components/Marquee.astro";
import ContactCTA from "../components/ContactCTA.astro";
import { services, values, site } from "../lib/site";
---
<Layout heroTone="light">
  <!-- HERO -->
  <section data-hero="full" class="grain relative flex min-h-[94svh] flex-col overflow-hidden bg-dark text-base">
    <div class="absolute inset-0">
      <div class="reveal-image absolute inset-0">
        <video
          class="ken-burns h-full w-full object-cover"
          autoplay muted loop playsinline
          poster="/images/lievense/hero-poster.jpg"
        >
          <source src="/images/lievense/oogst.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-dark/70 via-dark/25 to-dark"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-dark/80 via-dark/20 to-transparent"></div>
    </div>

    <div class="container-wide relative z-10 flex flex-1 flex-col justify-end pb-16 pt-40 md:pb-24 md:pt-52">
      <div class="max-w-4xl">
        <p class="eyebrow-bone reveal">Landbouwmachines en constructie · sinds {site.since}</p>
        <h1 class="reveal mt-7 type-display-xl text-base heading-balance">
          Machines die het <span class="text-accent-300">zware werk</span> aankunnen.
        </h1>
        <p class="reveal mt-7 type-lead max-w-xl text-base/85">
          Lievense Constructie ontwerpt en produceert bandoprapers voor maaidorsers en levert maatwerkconstructies en aandrijftechniek. Degelijk, doordacht en gebouwd voor het seizoen.
        </p>
        <div class="reveal mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a href="/bandoprapers" class="btn-primary bg-base text-ink hover:bg-accent-300">Bekijk de bandoprapers</a>
          <a href="/contact" class="btn-ghost border-base/30 text-base hover:bg-base/10">Neem contact op</a>
        </div>
      </div>
      <div class="reveal mt-14 flex items-center gap-6">
        <div class="scroll-cue text-base/40"></div>
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-base/60">Familiebedrijf · Zeeland · Elk merk maaidorser</p>
      </div>
    </div>
  </section>

  <!-- MANIFEST -->
  <section class="section-lg bg-base">
    <div class="container-wide">
      <div class="max-w-[1100px]">
        <p class="eyebrow reveal">Waar we voor staan</p>
        <h2 class="reveal mt-8 type-display-lg text-ink heading-balance">
          Een bandopraper is geen catalogusnummer. <span class="text-outline-ink">Hij past bij uw gewas.</span>
        </h2>
        <div class="reveal mt-12 grid gap-10 md:mt-16 lg:grid-cols-12">
          <p class="type-lead text-ink-muted lg:col-span-5 lg:col-start-7">
            Sinds 1966 bouwen we machines en constructies voor de landbouw. Geen standaard uit het schap, maar oplossingen die aansluiten op de maaidorser, het gewas en de manier van werken. Dat vraagt vakmanschap, en dat is precies wat er in de werkplaats staat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Marquee />

  <!-- DIENSTEN -->
  <section id="diensten" class="section bg-base-2">
    <div class="container-wide">
      <div class="mb-14 grid gap-6 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-7">
          <p class="eyebrow reveal">Diensten</p>
          <h2 class="reveal mt-6 type-display-md text-ink heading-balance">Vier dingen die we goed doen.</h2>
        </div>
        <div class="lg:col-span-4 lg:col-start-9 flex lg:justify-end">
          <a href="/diensten" class="btn-link reveal">Alle diensten</a>
        </div>
      </div>
      <div class="reveal-stagger grid gap-px overflow-hidden rounded-[6px] border border-line bg-line sm:grid-cols-2">
        {services.map((s) => (
          <a href={s.href} class="group flex flex-col bg-base p-8 transition-colors duration-500 hover:bg-base-2 md:p-10">
            <p class="font-mono text-xs tracking-[0.1em] text-accent-600">{s.num}</p>
            <h3 class="mt-5 font-display text-2xl text-ink leading-tight" style="font-stretch:112%;font-weight:700;">{s.title}</h3>
            <p class="mt-4 flex-1 text-ink-muted leading-relaxed text-[0.95rem]">{s.body}</p>
            <span class="mt-6 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-ink transition group-hover:gap-3.5 group-hover:text-accent-600">
              Meer <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EDITORIAL IMAGE BAND -->
  <section class="bg-base pt-16 pb-6 md:pt-24">
    <div class="container-wide">
      <div class="mb-10 max-w-2xl">
        <p class="eyebrow reveal">Uit de werkplaats</p>
        <h2 class="reveal mt-6 type-display-md text-ink heading-balance">Afgeleverd, klaar voor het land.</h2>
      </div>
      <div class="grid gap-5 lg:grid-cols-12">
        <figure class="reveal-image group relative col-span-12 aspect-[16/10] overflow-hidden rounded-[8px] lg:col-span-7">
          <img src="/images/lievense/bandopraper-angle.jpg" alt="Afgemonteerde gele bandopraper op de kade, klaar voor aflevering" class="h-full w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-[1.04]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
          <figcaption class="absolute bottom-5 left-6 font-mono text-xs uppercase tracking-[0.12em] text-base">Bandopraper · maatwerk</figcaption>
        </figure>
        <figure class="reveal-image group relative col-span-12 aspect-[16/10] overflow-hidden rounded-[8px] lg:col-span-5">
          <img src="/images/lievense/bandopraper-side.jpg" alt="Zijaanzicht van een bandopraper met hydraulische aandrijving" class="h-full w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-[1.04]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
          <figcaption class="absolute bottom-5 left-6 font-mono text-xs uppercase tracking-[0.12em] text-base">Aandrijving · hydraulisch</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- HERITAGE / STATS -->
  <section class="section bg-base">
    <div class="container-wide">
      <div class="mb-12 max-w-2xl">
        <p class="eyebrow reveal">Op ervaring gebouwd</p>
        <h2 class="reveal mt-6 type-display-md text-ink heading-balance">Bijna zestig jaar in de landbouw.</h2>
      </div>
      <div class="reveal-stagger grid gap-10 border-t border-line pt-12 sm:grid-cols-3">
        <div>
          <p class="font-display text-[clamp(3.5rem,9vw,7rem)] leading-none text-outline-ink" style="font-stretch:112%;font-weight:800;">1966</p>
          <p class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">Opgericht als loonbedrijf</p>
        </div>
        <div>
          <p class="font-display text-[clamp(3.5rem,9vw,7rem)] leading-none text-outline-ink" style="font-stretch:112%;font-weight:800;">2001</p>
          <p class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">Huibregtse Machinehandel toegevoegd</p>
        </div>
        <div>
          <p class="font-display text-[clamp(3.5rem,9vw,7rem)] leading-none text-accent-500" style="font-stretch:112%;font-weight:800;">Elk merk</p>
          <p class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-ink-muted">Maaidorser waarop we bouwen</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WAAROM / VALUES with image -->
  <section class="section bg-dark text-base grain relative overflow-hidden">
    <div class="container-wide relative z-10 grid gap-14 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <div class="lg:sticky lg:top-28">
          <p class="eyebrow-bone reveal">Waarom Lievense</p>
          <h2 class="reveal mt-6 type-display-md text-base heading-balance">Vakwerk dat u terugziet op het land.</h2>
          <figure class="reveal-image mt-10 aspect-[4/3] overflow-hidden rounded-[8px]">
            <img src="/images/lievense/fabricage-primer.jpg" alt="Bandopraper in de grondverf, vers uit de fabricage" class="h-full w-full object-cover" loading="lazy" />
          </figure>
        </div>
      </div>
      <div class="space-y-10 lg:col-span-6 lg:col-start-7">
        {values.map((v, i) => (
          <article class="reveal border-t border-base/15 pt-7">
            <div class="flex items-baseline gap-5">
              <span class="font-mono text-xs text-accent-300">{String(i + 1).padStart(2, "0")}</span>
              <div>
                <h3 class="type-display-sm text-base">{v.key}</h3>
                <p class="mt-3 text-base/70 leading-relaxed">{v.desc}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
